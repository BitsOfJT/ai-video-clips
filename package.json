{
  "name": "ai-video-clipper",
  "version": "1.0.2",
  "description": "AI-powered desktop video clipper for short-form content",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:release": "npm run download:models && npm run build:python && npm run download:ffmpeg && npm run build",
    "download:ffmpeg": "node scripts/download-ffmpeg.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/test-transcriber.js",
    "test:renderer": "node scripts/test-packaged-renderer.js",
    "test:editor": "node scripts/test-editor.js",
    "test:python": "python3 -m pytest python/tests/ -v",
    "download:models": "python3 python/download_models.py",
    "build:python": "python3 python/build.py"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "better-sqlite3": "^11.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.479.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.0.12",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.7",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.12",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^4.1.9"
  }
}
